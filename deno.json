{
  "version": "0.5.0",
  "license": "MIT",
  "compilerOptions": {
    "lib": ["deno.window"],
    "strict": true
  },
  "imports": {
    "@cliffy/ansi": "jsr:@cliffy/ansi@1",
    "@cliffy/keypress": "jsr:@cliffy/keypress@1",
    "@cross/service": "jsr:@cross/service@^1.0.7",
    "@std/assert": "jsr:@std/assert@1.0.19",
    "@std/fmt": "jsr:@std/fmt@^1.0.9",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/toml": "jsr:@std/toml@^1.0.11",
    "@std/yaml": "jsr:@std/yaml@^1.0.12"
  },
  "lint": {
    "exclude": ["scripts/", "site/"]
  },
  "tasks": {
    "install": "deno run -A scripts/install-from-source.ts",
    "dev": "deno run -A cli/src/main.ts",
    "test": "deno test --allow-all",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "check": "deno check cli/src/**/*.ts gateway/src/**/*.ts providers/src/**/*.ts tests/**/*.ts",
    "quality": "deno lint && deno fmt --check && deno check && deno test --allow-all",
    "compile": "deno compile --allow-net --allow-env --allow-run --allow-read --allow-write --output bin/modmux cli/src/main.ts"
  },
  "workspace": [
    "cli",
    "gateway",
    "providers"
  ]
}
