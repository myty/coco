{
  "compilerOptions": {
    "lib": ["deno.window"],
    "strict": true
  },
  "imports": {
    "@github/copilot-sdk": "npm:@github/copilot-sdk@0.1.29",
    "@std/assert": "jsr:@std/assert@1.0.19"
  },
  "tasks": {
    "dev": "deno run --allow-env --allow-net --allow-read --allow-write src/cli/main.ts",
    "test": "deno test --allow-all",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "check": "deno check src/**/*.ts tests/**/*.ts",
    "quality": "deno lint && deno fmt:check && deno check && deno test"
  },
  "nodeModulesDir": "auto"
}
